# density plot of monthly earnings log transformed (scale of 10) - Gender
PSPS_standardized_pay |>
  ggplot(aes(x = log10(agwork_monthly_pay_1))) +
  geom_histogram(aes(y = after_stat(count), fill = gender), alpha = 0.5) +
  scale_x_continuous(
    name = "Monthly earnings (log scale)",
    breaks = 1:6,
    labels = scales::label_dollar(prefix = "₱", scale = 1)(10 ^ (1:6)),
    expand = c(0, 0)
  ) +
  labs(
    y = NULL
  ) +
  scale_y_continuous(
    expand = c(0, 0),
    limits = c(0, 500)) +
  theme_bw() +
  theme(
    plot.margin = margin(t = 10, r = 20, b = 10, l = 20)
  )

